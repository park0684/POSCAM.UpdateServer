# 실제 값 파일은 Git에 커밋하지 않는다.
POSCAM_UPDATE_IMAGE_TAG=1.0.0
UPDATE_DB_CONNECTION=CHANGE_ME

# 최소 32자의 무작위 값으로 반드시 교체한다. CHANGE_ME 상태에서는 운영 시작 검증이 실패해야 한다.
UPDATE_INTERNAL_SERVICE_KEY=CHANGE_ME

# IIS → Ubuntu Nginx → UpdateServer의 정확한 2개 프록시 IP를 등록한다.
# NGINX_PROXY_IP: 컨테이너가 직접 연결 주체로 보는 Nginx/Docker Host IP.
# IIS_PROXY_IP: X-Forwarded-For 체인의 IIS Reverse Proxy IP.
# 0.0.0.0, ::, 광범위한 CIDR은 사용하지 않는다.
UPDATE_NGINX_PROXY_IP=CHANGE_ME
UPDATE_IIS_PROXY_IP=CHANGE_ME
